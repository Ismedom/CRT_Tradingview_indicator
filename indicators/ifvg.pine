// ============================================================
// FVG ASIA SESSION  |  Pine Script v5
// Trade only during Asia (00:00 – 09:00 UTC)
// Logic: Liquidity Sweep  →  FVG forms  →  Signal + RR zones
// ============================================================
//@version=5
indicator("FVG Asia Session [Sweep → FVG → RR]",
     shorttitle = "FVG ASIA",
     overlay    = true,
     max_lines_count  = 500,
     max_boxes_count  = 500,
     max_labels_count = 500)

// ─────────────────────────────────────────────
// ░░  INPUTS
// ─────────────────────────────────────────────

grp_sess = "═══  Asia Session  ═══"
i_asiaStart = input.int(0,  "Session Start (UTC hour)", minval=0, maxval=23, group=grp_sess,
     tooltip="Default 0 = midnight UTC = 07:00 Bangkok / 08:00 Singapore / Tokyo.")
i_asiaEnd   = input.int(9,  "Session End   (UTC hour)", minval=1, maxval=23, group=grp_sess,
     tooltip="Default 9 = 09:00 UTC = 16:00 Bangkok / 17:00 Singapore.")
i_shadeAsia = input.bool(true, "Shade Asia Session Background", group=grp_sess)

grp_liq = "═══  Liquidity Sweep  ═══"
i_pivLen    = input.int  (3,    "Pivot Length (bars each side)", minval=1, maxval=10, group=grp_liq,
     tooltip="Bars left/right to confirm a swing high/low.")
i_liqWin    = input.int  (10,   "Sweep Memory (bars)",           minval=2, maxval=30,  group=grp_liq,
     tooltip="After a sweep, signal is valid for this many bars while waiting for the FVG.")
i_liqBuf    = input.float(0.0,  "Sweep Buffer (%)",              minval=0.0, step=0.01, group=grp_liq,
     tooltip="Price must pierce the pivot by at least this % to count as a sweep.")
i_showSwMark = input.bool(true, "Show Sweep Marker on Chart",   group=grp_liq,
     tooltip="Paint a diamond on the candle that swept the pivot level.")

grp_fvg = "═══  FVG Detection  ═══"
i_minGapPct = input.float(0.05, "Min Gap Size (%)", minval=0.0, step=0.01, group=grp_fvg,
     tooltip="Minimum size of the imbalance gap as % of price. Reduce for crypto/indices.")
i_dir       = input.string("Both", "Signal Direction",
     options=["Both","Bullish Only","Bearish Only"], group=grp_fvg)

grp_rr = "═══  Risk / Reward  ═══"
i_entryType = input.string("FVG Mid", "Entry at",
     options=["FVG Mid","FVG Edge","Close"], group=grp_rr,
     tooltip="FVG Mid = midpoint of the gap (recommended for Asia). FVG Edge = near side. Close = signal bar close.")
i_slType    = input.string("Gap Edge", "Stop-Loss at",
     options=["Gap Edge","Last Pivot","Lookback"], group=grp_rr,
     tooltip="Gap Edge = tight SL just past the far side of the gap (recommended). Last Pivot = swept pivot. Lookback = n-bar extreme.")
i_slLookback = input.int  (5,   "SL Lookback (bars)", minval=1, maxval=30, group=grp_rr)
i_slBuf      = input.float(0.1, "SL Buffer (%)",      minval=0.0, step=0.05, group=grp_rr)
i_rr1        = input.float(1.5, "TP1 R:R",            minval=0.1, step=0.1,  group=grp_rr)
i_rr2        = input.float(3.0, "TP2 R:R",            minval=0.1, step=0.1,  group=grp_rr)

grp_vis = "═══  Visuals  ═══"
i_extBars    = input.int  (40,  "Box Extend Right (bars)", minval=5, maxval=500, group=grp_vis)
i_bullCol    = input.color(color.new(#00e676, 0), "Bullish Color", group=grp_vis)
i_bearCol    = input.color(color.new(#ff1744, 0), "Bearish Color", group=grp_vis)
i_alpha      = input.int  (82,  "Box Transparency",        minval=0, maxval=99, group=grp_vis)
i_showGap    = input.bool (true, "Shade FVG Gap Zone",     group=grp_vis)
i_showLabels = input.bool (true, "Show Price Labels",      group=grp_vis)
i_showDash   = input.bool (true, "Show Dashboard",         group=grp_vis)

// ─────────────────────────────────────────────
// ░░  ASIA SESSION GATE
// ─────────────────────────────────────────────

utcH     = hour(time, "UTC")
inAsia   = utcH >= i_asiaStart and utcH < i_asiaEnd

// Background shading
bgcolor(i_shadeAsia and inAsia ? color.new(#4a148c, 91) : na, title="Asia Background")

// ─────────────────────────────────────────────
// ░░  TREND & STRUCTURE  (for score / filter)
// ─────────────────────────────────────────────

ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
trendUp   = ema20 > ema50
trendDown = ema20 < ema50

swH = ta.pivothigh(high, 3, 3)
swL = ta.pivotlow (low,  3, 3)
var float lastSH = na
var float lastSL = na
if not na(swH)
    lastSH := swH
if not na(swL)
    lastSL := swL

bullStruct = not na(lastSL) and close > lastSL
bearStruct = not na(lastSH) and close < lastSH

// ─────────────────────────────────────────────
// ░░  LIQUIDITY SWEEP DETECTION
// ─────────────────────────────────────────────
// Pivot-based: track the most-recent confirmed pivot H/L.
// Sweep = wick through pivot by >= buffer  +  close reverses back.

pivH = ta.pivothigh(high, i_pivLen, i_pivLen)
pivL = ta.pivotlow (low,  i_pivLen, i_pivLen)

var float rPivH = na   // most recent confirmed pivot high
var float rPivL = na   // most recent confirmed pivot low
if not na(pivH)
    rPivH := pivH
if not na(pivL)
    rPivL := pivL

// Sweep conditions (only valid inside Asia session)
bullSwNow = inAsia and not na(rPivL) and low  < rPivL * (1 - i_liqBuf / 100) and close > rPivL  // wick below, close back above
bearSwNow = inAsia and not na(rPivH) and high > rPivH * (1 + i_liqBuf / 100) and close < rPivH  // wick above, close back below

// Remember sweep for i_liqWin bars so FVG forming 1–3 bars later still qualifies
var int bullSwAge = 999
var int bearSwAge = 999
if bullSwNow
    bullSwAge := 0
else
    bullSwAge := math.min(bullSwAge + 1, 999)
if bearSwNow
    bearSwAge := 0
else
    bearSwAge := math.min(bearSwAge + 1, 999)

bullLiqReady = bullSwAge <= i_liqWin    // sweep happened recently (bull setup)
bearLiqReady = bearSwAge <= i_liqWin    // sweep happened recently (bear setup)

// ─────────────────────────────────────────────
// ░░  FVG DETECTION  (3-candle imbalance)
// ─────────────────────────────────────────────
// Bullish FVG : gap between high[2] and low[0]  →  high[2] < low[0]
//   After a bullish sweep (sweeping lows), price impulses UP leaving a gap.
//   Entry = retrace into the FVG zone to go long.
//
// Bearish FVG : gap between low[2] and high[0]  →  low[2] > high[0]
//   After a bearish sweep (sweeping highs), price impulses DOWN leaving a gap.
//   Entry = retrace into the FVG zone to go short.

minGap = close * i_minGapPct / 100

// Bullish FVG: gap between candle[-2].high and candle[0].low (price shot up)
rawBull = high[2] < low[0] and (low[0] - high[2]) >= minGap

// Bearish FVG: gap between candle[-2].low and candle[0].high (price shot down)
rawBear = low[2] > high[0] and (low[2] - high[0]) >= minGap

// Gap boundaries
bullGapTop = low[0]    // top of the bullish FVG
bullGapBot = high[2]   // bottom of the bullish FVG
bearGapTop = low[2]    // top of the bearish FVG
bearGapBot = high[0]   // bottom of the bearish FVG

// ─────────────────────────────────────────────
// ░░  FINAL SIGNAL
//     FVG formed  +  sweep happened recently  +  in Asia session
// ─────────────────────────────────────────────

bullSig = rawBull and bullLiqReady and inAsia and trendUp and bullStruct
bullSig := bullSig and (i_dir == "Both" or i_dir == "Bullish Only")

bearSig = rawBear and bearLiqReady and inAsia and trendDown and bearStruct
bearSig := bearSig and (i_dir == "Both" or i_dir == "Bearish Only")

// ─────────────────────────────────────────────
// ░░  ENTRY / SL / TP  LEVELS
// ─────────────────────────────────────────────

// Bull levels
bullEntry = i_entryType == "FVG Mid"  ? (bullGapTop + bullGapBot) / 2 : i_entryType == "FVG Edge" ? bullGapBot : close
bullSL    = i_slType == "Gap Edge"    ? bullGapBot * (1 - i_slBuf / 100) : i_slType == "Last Pivot" ? (not na(rPivL) ? rPivL * (1 - i_slBuf / 100) : bullGapBot * (1 - i_slBuf / 100)) : ta.lowest(low, i_slLookback) * (1 - i_slBuf / 100)
bullRisk  = math.max(math.abs(bullEntry - bullSL), syminfo.mintick)
bullTP1   = bullEntry + bullRisk * i_rr1
bullTP2   = bullEntry + bullRisk * i_rr2

// Bear levels
bearEntry = i_entryType == "FVG Mid"  ? (bearGapTop + bearGapBot) / 2 : i_entryType == "FVG Edge" ? bearGapTop : close
bearSL    = i_slType == "Gap Edge"    ? bearGapTop * (1 + i_slBuf / 100) : i_slType == "Last Pivot" ? (not na(rPivH) ? rPivH * (1 + i_slBuf / 100) : bearGapTop * (1 + i_slBuf / 100)) : ta.highest(high, i_slLookback) * (1 + i_slBuf / 100)
bearRisk  = math.max(math.abs(bearSL - bearEntry), syminfo.mintick)
bearTP1   = bearEntry - bearRisk * i_rr1
bearTP2   = bearEntry - bearRisk * i_rr2

// ─────────────────────────────────────────────
// ░░  PLOTSHAPE  (must be in global scope)
// ─────────────────────────────────────────────

// Main signals
plotshape(bullSig, title="Bull FVG Asia",
     style=shape.triangleup, location=location.belowbar,
     color=i_bullCol, size=size.normal)

plotshape(bearSig, title="Bear FVG Asia",
     style=shape.triangledown, location=location.abovebar,
     color=i_bearCol, size=size.normal)

// Sweep markers (small diamonds)
plotshape(i_showSwMark and bullSwNow, title="Bull Sweep",
     style=shape.diamond, location=location.belowbar,
     color=color.new(#00e676, 15), size=size.small)

plotshape(i_showSwMark and bearSwNow, title="Bear Sweep",
     style=shape.diamond, location=location.abovebar,
     color=color.new(#ff1744, 15), size=size.small)

// EMAs
plot(ema20, "EMA 20", color=color.new(color.orange, 50), linewidth=1)
plot(ema50, "EMA 50", color=color.new(color.blue,   50), linewidth=1)

// ─────────────────────────────────────────────
// ░░  DRAW R:R BOXES + LINES + LABELS
// ─────────────────────────────────────────────

var box   bxGap  = na
var box   bxSL   = na
var box   bxTP1  = na
var box   bxTP2  = na
var line  lnEnt  = na
var line  lnSL   = na
var line  lnTP1  = na
var line  lnTP2  = na
var label lbEnt  = na
var label lbSL   = na
var label lbTP1  = na
var label lbTP2  = na

var string lastSig   = "—"
var int    sigCount  = 0
var int    lastScore = 0

// ── BULLISH ──────────────────────────────────
if bullSig
    sigCount += 1
    lastSig  := "Bullish"
    R = bar_index + i_extBars

    // FVG gap highlight
    if i_showGap
        bxGap := box.new(bar_index - 2, bullGapTop, R, bullGapBot,
             border_color=color.new(i_bullCol, 55),
             bgcolor     =color.new(i_bullCol, 73))

    // SL zone (red)
    bxSL  := box.new(bar_index, bullEntry, R, bullSL,
         border_color=i_bearCol, bgcolor=color.new(i_bearCol, i_alpha))
    // TP1 zone
    bxTP1 := box.new(bar_index, bullTP1,   R, bullEntry,
         border_color=i_bullCol, bgcolor=color.new(i_bullCol, i_alpha))
    // TP2 zone (lighter)
    bxTP2 := box.new(bar_index, bullTP2,   R, bullTP1,
         border_color=color.new(i_bullCol, 40),
         bgcolor=color.new(i_bullCol, math.min(i_alpha + 7, 99)))

    lnEnt  := line.new(bar_index, bullEntry, R, bullEntry, color=color.white,           width=2, style=line.style_dashed)
    lnSL   := line.new(bar_index, bullSL,    R, bullSL,    color=i_bearCol,             width=1, style=line.style_solid)
    lnTP1  := line.new(bar_index, bullTP1,   R, bullTP1,   color=i_bullCol,             width=1, style=line.style_dotted)
    lnTP2  := line.new(bar_index, bullTP2,   R, bullTP2,   color=color.new(i_bullCol,40),width=1,style=line.style_dotted)

    if i_showLabels
        lbEnt  := label.new(R, bullEntry, "Entry  " + str.tostring(math.round(bullEntry, 2)),
             style=label.style_label_left, color=color.new(#1a1a2e,5), textcolor=color.white, size=size.small)
        lbSL   := label.new(R, bullSL,    "SL  "    + str.tostring(math.round(bullSL,    2)),
             style=label.style_label_left, color=color.new(i_bearCol,10), textcolor=color.white, size=size.small)
        lbTP1  := label.new(R, bullTP1,   "TP1 (" + str.tostring(i_rr1) + "R)  " + str.tostring(math.round(bullTP1, 2)),
             style=label.style_label_left, color=color.new(i_bullCol,10), textcolor=color.white, size=size.small)
        lbTP2  := label.new(R, bullTP2,   "TP2 (" + str.tostring(i_rr2) + "R)  " + str.tostring(math.round(bullTP2, 2)),
             style=label.style_label_left, color=color.new(i_bullCol,35), textcolor=color.white, size=size.small)

// ── BEARISH ──────────────────────────────────
if bearSig
    sigCount += 1
    lastSig  := "Bearish"
    R = bar_index + i_extBars

    if i_showGap
        bxGap := box.new(bar_index - 2, bearGapTop, R, bearGapBot,
             border_color=color.new(i_bearCol, 55),
             bgcolor     =color.new(i_bearCol, 73))

    bxSL  := box.new(bar_index, bearSL,    R, bearEntry,
         border_color=i_bearCol, bgcolor=color.new(i_bearCol, i_alpha))
    bxTP1 := box.new(bar_index, bearEntry, R, bearTP1,
         border_color=i_bullCol, bgcolor=color.new(i_bullCol, i_alpha))
    bxTP2 := box.new(bar_index, bearTP1,   R, bearTP2,
         border_color=color.new(i_bullCol, 40),
         bgcolor=color.new(i_bullCol, math.min(i_alpha + 7, 99)))

    lnEnt  := line.new(bar_index, bearEntry, R, bearEntry, color=color.white,           width=2, style=line.style_dashed)
    lnSL   := line.new(bar_index, bearSL,    R, bearSL,    color=i_bearCol,             width=1, style=line.style_solid)
    lnTP1  := line.new(bar_index, bearTP1,   R, bearTP1,   color=i_bullCol,             width=1, style=line.style_dotted)
    lnTP2  := line.new(bar_index, bearTP2,   R, bearTP2,   color=color.new(i_bullCol,40),width=1,style=line.style_dotted)

    if i_showLabels
        lbEnt  := label.new(R, bearEntry, "Entry  " + str.tostring(math.round(bearEntry, 2)),
             style=label.style_label_left, color=color.new(#1a1a2e,5), textcolor=color.white, size=size.small)
        lbSL   := label.new(R, bearSL,    "SL  "    + str.tostring(math.round(bearSL,    2)),
             style=label.style_label_left, color=color.new(i_bearCol,10), textcolor=color.white, size=size.small)
        lbTP1  := label.new(R, bearTP1,   "TP1 (" + str.tostring(i_rr1) + "R)  " + str.tostring(math.round(bearTP1, 2)),
             style=label.style_label_left, color=color.new(i_bullCol,10), textcolor=color.white, size=size.small)
        lbTP2  := label.new(R, bearTP2,   "TP2 (" + str.tostring(i_rr2) + "R)  " + str.tostring(math.round(bearTP2, 2)),
             style=label.style_label_left, color=color.new(i_bullCol,35), textcolor=color.white, size=size.small)

// ─────────────────────────────────────────────
// ░░  DASHBOARD
// ─────────────────────────────────────────────

var table dash = table.new(position.top_right, 2, 10,
     border_width=1,
     border_color=color.new(color.gray, 55),
     bgcolor     =color.new(#1a1a2e, 8))

if i_showDash and barstate.islast
    // Header
    hdrCol = inAsia ? color.new(#4a148c, 15) : color.new(#37474f, 40)
    table.cell(dash, 0, 0, "FVG  ASIA  SESSION", text_color=color.white, bgcolor=hdrCol, text_size=size.normal, text_halign=text.align_center)
    table.cell(dash, 1, 0, inAsia ? "ACTIVE" : "OFF-HOURS", text_color=color.white, bgcolor=hdrCol, text_size=size.normal, text_halign=text.align_center)

    // Session clock
    asiaStr = "UTC " + str.tostring(i_asiaStart) + ":00 – " + str.tostring(i_asiaEnd) + ":00  |  Now " + str.tostring(utcH) + "h UTC"
    table.cell(dash, 0, 1, "Session Window", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 1, asiaStr, text_color=color.white, bgcolor=inAsia ? color.new(#4a148c, 45) : color.new(color.gray, 50))

    // Trend
    trendLbl = trendUp ? "Up (EMA20>50)" : trendDown ? "Down (EMA20<50)" : "Ranging"
    trendCol = trendUp ? color.new(#00e676, 25) : trendDown ? color.new(#ff1744, 25) : color.new(color.gray, 25)
    table.cell(dash, 0, 2, "Trend", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 2, trendLbl, text_color=color.white, bgcolor=trendCol)

    // Structure
    strLbl = bullStruct ? "Bullish (above SwL)" : bearStruct ? "Bearish (below SwH)" : "Neutral"
    strCol = bullStruct ? color.new(#00e676, 40) : bearStruct ? color.new(#ff1744, 40) : color.new(color.gray, 40)
    table.cell(dash, 0, 3, "Structure", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 3, strLbl, text_color=color.white, bgcolor=strCol)

    // Bull sweep state
    bSwLbl = bullSwNow ? "SWEPT  now" : bullLiqReady ? "Ready  " + str.tostring(bullSwAge) + "b ago" : "Waiting"
    bSwCol = bullSwNow ? color.new(#00e676, 10) : bullLiqReady ? color.new(color.orange, 25) : color.new(color.gray, 55)
    table.cell(dash, 0, 4, "Bull Sweep", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 4, bSwLbl, text_color=color.white, bgcolor=bSwCol)

    // Bear sweep state
    rSwLbl = bearSwNow ? "SWEPT  now" : bearLiqReady ? "Ready  " + str.tostring(bearSwAge) + "b ago" : "Waiting"
    rSwCol = bearSwNow ? color.new(#ff1744, 10) : bearLiqReady ? color.new(color.orange, 25) : color.new(color.gray, 55)
    table.cell(dash, 0, 5, "Bear Sweep", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 5, rSwLbl, text_color=color.white, bgcolor=rSwCol)

    // Last signal
    sigCol = lastSig == "Bullish" ? color.new(#00e676, 30) : lastSig == "Bearish" ? color.new(#ff1744, 30) : color.new(color.gray, 50)
    table.cell(dash, 0, 6, "Last Signal", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 6, lastSig, text_color=color.white, bgcolor=sigCol)

    // R:R
    table.cell(dash, 0, 7, "R:R  TP1 / TP2", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 7, str.tostring(i_rr1) + "R  /  " + str.tostring(i_rr2) + "R", text_color=color.white, bgcolor=color.new(color.gray, 50))

    // Entry mode
    table.cell(dash, 0, 8, "Entry / SL Mode", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 8, i_entryType + "  /  " + i_slType, text_color=color.white, bgcolor=color.new(color.gray, 50))

    // Total signals
    table.cell(dash, 0, 9, "Total Signals", text_color=color.white, bgcolor=color.new(color.gray, 70))
    table.cell(dash, 1, 9, str.tostring(sigCount), text_color=color.white, bgcolor=color.new(color.gray, 50))

// ─────────────────────────────────────────────
// ░░  ALERTS
// ─────────────────────────────────────────────
alertcondition(bullSig, title="Asia Bull FVG Signal",
     message="ASIA BULL FVG on {{ticker}} @ {{close}} | Sweep cleared, FVG Entry/SL/TP plotted.")
alertcondition(bearSig, title="Asia Bear FVG Signal",
     message="ASIA BEAR FVG on {{ticker}} @ {{close}} | Sweep cleared, FVG Entry/SL/TP plotted.")
alertcondition(bullSig or bearSig, title="Asia FVG Signal (Any)",
     message="ASIA FVG Signal on {{ticker}} @ {{close}} | Liquidity swept, FVG confirmed.")
alertcondition(bullSwNow, title="Asia Bull Sweep",
     message="ASIA BULL SWEEP on {{ticker}} @ {{close}} | Pivot low taken, watching for FVG.")
alertcondition(bearSwNow, title="Asia Bear Sweep",
     message="ASIA BEAR SWEEP on {{ticker}} @ {{close}} | Pivot high taken, watching for FVG.")