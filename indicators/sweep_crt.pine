//@version=5
indicator("HTF FVG + Entry TF Reversal FVG", shorttitle="HTF·FVG·Entry", overlay=true, max_labels_count = 500, max_lines_count  = 500, max_boxes_count  = 500)

// ─────────────────────────────────────────────
// TRADING STYLE
// ─────────────────────────────────────────────
grp_style = "🎯 Trading Style"
style = input.string("Intraday", "Style Preset", options=["Scalper", "Intraday", "Swing", "Position"], group=grp_style, tooltip="Sets HTF, Entry TF suggestions, RR, and SL automatically.")

// ─────────────────────────────────────────────
// HTF + ENTRY TF PER STYLE
// Scalper  : HTF=15M,  Entry=1M–3M
// Intraday : HTF=1H/4H, Entry=5M–15M
// Swing    : HTF=4H/D,  Entry=1H
// Position : HTF=W,     Entry=D
// ─────────────────────────────────────────────
grp_tf = "⏱ Timeframe Settings"

htf_tf = input.timeframe("60", "HTF Timeframe (FVG Source)", group=grp_tf, tooltip="Scalper→15 | Intraday→60 or 240 | Swing→240 or D | Position→W")

// ─────────────────────────────────────────────
// FVG SETTINGS
// ─────────────────────────────────────────────
grp_fvg = "⚡ FVG Settings"

fvg_min_pct = input.float(0.0, "Min FVG Size (points, 0=any)", minval=0.0, step=0.1, group=grp_fvg, tooltip="Set to 0 to catch all FVGs. Increase to filter tiny gaps. For Gold use 0.5–2.0")

show_htf_fvg   = input.bool(true,  "Show HTF FVG Zones",             group=grp_fvg)
show_entry_fvg = input.bool(true,  "Show Entry TF Reversal FVG",     group=grp_fvg)
htf_fvg_extend = input.bool(true,  "Extend HTF FVG Until Mitigated", group=grp_fvg)
max_htf_fvg    = input.int(5, "Max HTF FVGs on Chart", minval=1, maxval=20, group=grp_fvg)

// How deep into the FVG price must reach before
// the reversal FVG is valid (0=just touch, 1=full)
fvg_respect_depth = input.float(0.5, "FVG Respect Depth (0–1)", minval=0.0, maxval=1.0, step=0.1, group=grp_fvg, tooltip="0 = price just touches FVG edge to trigger\n0.5 = price reaches midpoint\n1.0 = price fills entire FVG\nLower = more signals, higher = stronger confirmation")

// ─────────────────────────────────────────────
// RR SETTINGS — Auto by style, manual override
// ─────────────────────────────────────────────
grp_rr = "🎯 RR Settings"

auto_rr = input.bool(true, "Auto RR from Style Preset", group=grp_rr)
man_rr       = input.float(2.0, "Manual RR Ratio",    minval=1.0, maxval=10.0, step=0.5, group=grp_rr)
man_sl_mult  = input.float(0.5, "Manual SL ATR Mult", minval=0.1, maxval=5.0,  step=0.1, group=grp_rr)
man_box_w    = input.int(30,    "Manual Box Width",   minval=5,   maxval=300,  step=5,   group=grp_rr)

preset_rr_val = style == "Scalper" ? 1.5 : style == "Intraday" ? 2.0 : style == "Swing" ? 3.0 : 4.0

preset_sl_val = style == "Scalper" ? 0.3 : style == "Intraday" ? 0.5 : style == "Swing" ? 1.0 : 1.5

preset_bw_val = style == "Scalper" ? 15 : style == "Intraday" ? 30 : style == "Swing" ? 60 : 100

f_rr    = auto_rr ? preset_rr_val : man_rr
f_sl    = auto_rr ? preset_sl_val : man_sl_mult
f_bw    = auto_rr ? preset_bw_val : man_box_w

// ─────────────────────────────────────────────
// COLORS
// ─────────────────────────────────────────────
grp_col = "🎨 Colors"
bull_htf_col  = input.color(color.new(#00E676, 82), "HTF Bull FVG",      group=grp_col)
bear_htf_col  = input.color(color.new(#FF1744, 82), "HTF Bear FVG",      group=grp_col)
bull_rev_col  = input.color(color.new(#00BCD4, 75), "Entry Bull Rev FVG",group=grp_col)
bear_rev_col  = input.color(color.new(#FF9800, 75), "Entry Bear Rev FVG",group=grp_col)
tp_col        = input.color(color.new(#80CBC4, 45), "TP Box",            group=grp_col)
sl_col        = input.color(color.new(#F48FB1, 45), "SL Box",            group=grp_col)

// ─────────────────────────────────────────────
// UTILITY
// ─────────────────────────────────────────────
atr14 = ta.atr(14)

// ─────────────────────────────────────────────
// HTF DATA FETCH
// ─────────────────────────────────────────────
[htf_h0, htf_h1, htf_h2] = request.security(syminfo.tickerid, htf_tf, [high[0], high[1], high[2]], lookahead=barmerge.lookahead_off)
[htf_l0, htf_l1, htf_l2] = request.security(syminfo.tickerid, htf_tf, [low[0], low[1], low[2]], lookahead=barmerge.lookahead_off)
[htf_c0, htf_c1] = request.security(syminfo.tickerid, htf_tf, [close[0], close[1]], lookahead=barmerge.lookahead_off)

// ─────────────────────────────────────────────
// HTF FVG DETECTION
// Bull FVG: candle[2] high < candle[0] low — upward gap
// Bear FVG: candle[2] low  > candle[0] high — downward gap
// ─────────────────────────────────────────────
htf_bull_fvg = htf_l0 > htf_h2 and (htf_l0 - htf_h2) >= fvg_min_pct
htf_bear_fvg = htf_h0 < htf_l2 and (htf_l2 - htf_h0) >= fvg_min_pct

htf_bull_fvg_top = htf_l0
htf_bull_fvg_bot = htf_h2
htf_bear_fvg_top = htf_l2
htf_bear_fvg_bot = htf_h0

// ─────────────────────────────────────────────
// HTF FVG ZONE STORAGE + DRAWING
// ─────────────────────────────────────────────
var float[] fvg_top     = array.new_float()
var float[] fvg_bot     = array.new_float()
var bool[]  fvg_bull    = array.new_bool()
var bool[]  fvg_active  = array.new_bool()
var box[]   fvg_box_arr = array.new_box()
var int[]   fvg_bar_arr = array.new_int()

f_add_fvg(top, bot, is_bull) =>
    // Trim if over max
    if array.size(fvg_top) >= max_htf_fvg
        old_box = array.shift(fvg_box_arr)
        box.delete(old_box)
        array.shift(fvg_top)
        array.shift(fvg_bot)
        array.shift(fvg_bull)
        array.shift(fvg_active)
        array.shift(fvg_bar_arr)

    bg = is_bull ? bull_htf_col : bear_htf_col
    bc = is_bull ? color.new(#00E676, 50) : color.new(#FF1744, 50)
    b  = box.new(bar_index, top, bar_index + 500, bot, border_color=bc, border_width=1, bgcolor=bg)

    // Midpoint label
    mid   = (top + bot) / 2
    tag   = is_bull ? "▲ HTF Bull FVG" : "▼ HTF Bear FVG"
    tcol  = is_bull ? color.new(#00E676, 0) : color.new(#FF1744, 0)
    bgcol = is_bull ? color.new(#0B3D1A, 0) : color.new(#3D0B0B, 0)
    label.new(bar_index, top, tag + " [" + htf_tf + "M]  " + str.tostring(math.round(bot, 2)) + "–" + str.tostring(math.round(top, 2)), color=bgcol, textcolor=tcol, style=label.style_label_right, size=size.tiny)

    array.push(fvg_top,     top)
    array.push(fvg_bot,     bot)
    array.push(fvg_bull,    is_bull)
    array.push(fvg_active,  true)
    array.push(fvg_box_arr, b)
    array.push(fvg_bar_arr, bar_index)

// Add new FVGs
if htf_bull_fvg
    f_add_fvg(htf_bull_fvg_top, htf_bull_fvg_bot, true)

if htf_bear_fvg
    f_add_fvg(htf_bear_fvg_top, htf_bear_fvg_bot, false)

// ─────────────────────────────────────────────
// TRACK WHICH HTF FVG PRICE IS RESPECTING
// "Respect" = price wicked INTO the FVG zone
// but has NOT fully closed through it
// This is the "price touched FVG" condition
// ─────────────────────────────────────────────
var bool in_bull_fvg  = false
var bool in_bear_fvg  = false
var float active_bull_fvg_top = na
var float active_bull_fvg_bot = na
var float active_bear_fvg_top = na
var float active_bear_fvg_bot = na

in_bull_fvg  := false
in_bear_fvg  := false

if array.size(fvg_top) > 0
    for i = array.size(fvg_top) - 1 to 0
        if array.get(fvg_active, i)
            top     = array.get(fvg_top, i)
            bot     = array.get(fvg_bot, i)
            is_bull = array.get(fvg_bull, i)
            fvg_mid = bot + (top - bot) * fvg_respect_depth

            // Bull FVG: price wicks down into zone
            // Respect = low touched zone, close still above bot
            if is_bull
                if low <= top and low >= bot and close > fvg_mid
                    in_bull_fvg          := true
                    active_bull_fvg_top  := top
                    active_bull_fvg_bot  := bot
                    // Shade box to show it's being respected
                    box.set_bgcolor(array.get(fvg_box_arr, i),
                         color.new(#00E676, 70))

                // Fully mitigated — price closed below the FVG
                if close < bot
                    array.set(fvg_active, i, false)
                    box.set_bgcolor(array.get(fvg_box_arr, i),
                         color.new(#00E676, 94))
                    if htf_fvg_extend
                        box.set_right(array.get(fvg_box_arr, i), bar_index)

            // Bear FVG: price wicks up into zone
            if not is_bull
                if high >= bot and high <= top and close < fvg_mid
                    in_bear_fvg          := true
                    active_bear_fvg_top  := top
                    active_bear_fvg_bot  := bot
                    box.set_bgcolor(array.get(fvg_box_arr, i),
                         color.new(#FF1744, 70))

                if close > top
                    array.set(fvg_active, i, false)
                    box.set_bgcolor(array.get(fvg_box_arr, i),
                         color.new(#FF1744, 94))
                    if htf_fvg_extend
                        box.set_right(array.get(fvg_box_arr, i), bar_index)

// ─────────────────────────────────────────────
// ENTRY TF REVERSAL FVG DETECTION
// After price respects HTF FVG, look for
// an immediate FVG in the opposite direction
// on the current (entry) timeframe
//
// Bull reversal FVG (inside bull HTF FVG):
//   Candle[2] high < Candle[0] low
//   AND current candle is bullish
//   AND formed while price is in the bull FVG
//
// Bear reversal FVG (inside bear HTF FVG):
//   Candle[2] low > Candle[0] high
//   AND current candle is bearish
//   AND formed while price is in the bear FVG
// ─────────────────────────────────────────────
entry_bull_fvg_top = low[0]
entry_bull_fvg_bot = high[2]
entry_bull_fvg_ok  = entry_bull_fvg_top > entry_bull_fvg_bot and
                     close > open and
                     (entry_bull_fvg_top - entry_bull_fvg_bot) >= fvg_min_pct

entry_bear_fvg_top = low[2]
entry_bear_fvg_bot = high[0]
entry_bear_fvg_ok  = entry_bear_fvg_top > entry_bear_fvg_bot and
                     close < open and
                     (entry_bear_fvg_top - entry_bear_fvg_bot) >= fvg_min_pct

// ─────────────────────────────────────────────
// FINAL SIGNAL
// HTF FVG respected + Entry TF reversal FVG
// ─────────────────────────────────────────────
final_bull = in_bull_fvg and entry_bull_fvg_ok
final_bear = in_bear_fvg and entry_bear_fvg_ok

// ─────────────────────────────────────────────
// DRAW ENTRY REVERSAL FVG BOX
// Small box showing where the reversal FVG formed
// ─────────────────────────────────────────────
if show_entry_fvg and final_bull
    box.new(bar_index - 2, entry_bull_fvg_top, bar_index, entry_bull_fvg_bot, border_color=color.new(#00BCD4, 20), border_width=1, bgcolor=bull_rev_col)
    label.new(bar_index - 1, entry_bull_fvg_top, "Rev FVG", color=color.new(#00BCD4, 0), textcolor=color.white, style=label.style_label_up, size=size.tiny)

if show_entry_fvg and final_bear
    box.new(bar_index - 2, entry_bear_fvg_top, bar_index, entry_bear_fvg_bot, border_color=color.new(#FF9800, 20), border_width=1, bgcolor=bear_rev_col)
    label.new(bar_index - 1, entry_bear_fvg_bot, "Rev FVG", color=color.new(#FF9800, 0), textcolor=color.white, style=label.style_label_down, size=size.tiny)

// ─────────────────────────────────────────────
// RR BOX — Clean teal/pink style
// ─────────────────────────────────────────────
if final_bull
    entry  = close
    sl     = entry - atr14 * f_sl
    tp     = entry + (entry - sl) * f_rr
    risk   = entry - sl
    rr_act = risk > 0 ? (tp - entry) / risk : f_rr

    box.new(bar_index, tp, bar_index + f_bw, entry, border_color=color.new(#80CBC4, 10), border_width=1, bgcolor=tp_col)
    box.new(bar_index, entry, bar_index + f_bw, sl, border_color=color.new(#F48FB1, 10), border_width=1, bgcolor=sl_col)
    line.new(bar_index, entry, bar_index + f_bw, entry, color=color.new(#ECEFF1, 30), width=2)
    label.new(bar_index + f_bw, tp, "  TP  " + str.tostring(math.round(tp, 2)) + "   " + str.tostring(math.round(rr_act, 1)) + "R", color=color.new(#0B3D35, 0), textcolor=color.new(#80CBC4, 0), style=label.style_label_left, size=size.small)
    label.new(bar_index + f_bw, entry, "  ENTRY  " + str.tostring(math.round(entry, 2)), color=color.new(#1C2833, 0), textcolor=color.new(#ECEFF1, 0), style=label.style_label_left, size=size.small)
    label.new(bar_index + f_bw, sl, "  SL  " + str.tostring(math.round(sl, 2)), color=color.new(#3D0B1A, 0), textcolor=color.new(#F48FB1, 0), style=label.style_label_left, size=size.small)
    label.new(bar_index, low - atr14 * 1.2, "▲ BUY  [" + style + " · HTF:" + htf_tf + "]", color=color.new(#00E676, 0), textcolor=color.white, style=label.style_label_up, size=size.normal)

if final_bear
    entry  = close
    sl     = entry + atr14 * f_sl
    tp     = entry - (sl - entry) * f_rr
    risk   = sl    - entry
    rr_act = risk > 0 ? (entry - tp) / risk : f_rr

    box.new(bar_index, entry, bar_index + f_bw, tp, border_color=color.new(#80CBC4, 10), border_width=1, bgcolor=tp_col)
    box.new(bar_index, sl, bar_index + f_bw, entry, border_color=color.new(#F48FB1, 10), border_width=1, bgcolor=sl_col)
    line.new(bar_index, entry, bar_index + f_bw, entry, color=color.new(#ECEFF1, 30), width=2)
    label.new(bar_index + f_bw, sl, "  SL  " + str.tostring(math.round(sl, 2)), color=color.new(#3D0B1A, 0), textcolor=color.new(#F48FB1, 0), style=label.style_label_left, size=size.small)
    label.new(bar_index + f_bw, entry, "  ENTRY  " + str.tostring(math.round(entry, 2)), color=color.new(#1C2833, 0), textcolor=color.new(#ECEFF1, 0), style=label.style_label_left, size=size.small)
    label.new(bar_index + f_bw, tp, "  TP  " + str.tostring(math.round(tp, 2)) + "   " + str.tostring(math.round(rr_act, 1)) + "R", color=color.new(#0B3D35, 0), textcolor=color.new(#80CBC4, 0), style=label.style_label_left, size=size.small)
    label.new(bar_index, high + atr14 * 1.2, "▼ SELL  [" + style + " · HTF:" + htf_tf + "]", color=color.new(#FF1744, 0), textcolor=color.white, style=label.style_label_down, size=size.normal)

// ─────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────
alertcondition(final_bull, title="HTF FVG BUY", message="🟢 HTF FVG + Rev FVG BUY | {{ticker}} | {{interval}} | {{close}}")
alertcondition(final_bear, title="HTF FVG SELL", message="🔴 HTF FVG + Rev FVG SELL | {{ticker}} | {{interval}} | {{close}}")

// ─────────────────────────────────────────────
// DASHBOARD
// ─────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 10, bgcolor=#0D1117, border_color=color.new(#80CBC4, 40), border_width=1, frame_color=color.new(#80CBC4, 20), frame_width=2)

if barstate.islast
    table.cell(dash, 0, 0, "HTF FVG + Rev FVG", text_color=#80CBC4, text_size=size.small, bgcolor=#161B22, text_halign=text.align_center)
    table.cell(dash, 1, 0, style, text_color=#FFA726, text_size=size.small, bgcolor=#161B22, text_halign=text.align_center)
    table.cell(dash, 0, 1, "HTF TF",       text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 1, htf_tf,         text_color=#FFA726,      text_size=size.tiny)
    table.cell(dash, 0, 2, "RR",           text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(f_rr) + "R", text_color=#80CBC4, text_size=size.tiny)
    table.cell(dash, 0, 3, "SL",           text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(f_sl) + "× ATR", text_color=#80CBC4, text_size=size.tiny)
    table.cell(dash, 0, 4, "Active FVGs",  text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(array.size(fvg_top)), text_color=#FFA726, text_size=size.tiny)
    table.cell(dash, 0, 5, "In Bull FVG",  text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 5, in_bull_fvg ? "✅ YES" : "—", text_color=in_bull_fvg ? #00E676 : color.gray, text_size=size.tiny)
    table.cell(dash, 0, 6, "In Bear FVG",  text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 6, in_bear_fvg ? "✅ YES" : "—", text_color=in_bear_fvg ? #FF1744 : color.gray, text_size=size.tiny)
    table.cell(dash, 0, 7, "Rev Bull FVG", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 7, entry_bull_fvg_ok ? "✅ FORMED" : "—", text_color=entry_bull_fvg_ok ? #00BCD4 : color.gray, text_size=size.tiny)
    table.cell(dash, 0, 8, "Rev Bear FVG", text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 8, entry_bear_fvg_ok ? "✅ FORMED" : "—", text_color=entry_bear_fvg_ok ? #FF9800 : color.gray, text_size=size.tiny)
    table.cell(dash, 0, 9, "▶ SIGNAL",    text_color=#80CBC4, text_size=size.tiny, bgcolor=#161B22)
    table.cell(dash, 1, 9, final_bull ? "▲ BUY" : final_bear ? "▼ SELL" : "— Waiting —", text_color=final_bull ? #00E676 : final_bear ? #FF1744 : color.gray, text_size=size.small, bgcolor=#161B22)